<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/onto.owl"
         xmlns="http://test.org/onto.owl#">

<owl:Ontology rdf:about="http://test.org/onto.owl"/>

<owl:ObjectProperty rdf:about="#belongsTo">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSymptom">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#Symptom"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Department">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#System">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Symptom">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Mechanical">
  <rdf:type rdf:resource="#Department"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Communication">
  <rdf:type rdf:resource="#System"/>
  <belongsTo rdf:resource="#Mechanical"/>
  <hasSymptom rdf:resource="#PTC"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PTC">
  <rdf:type rdf:resource="#Symptom"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Engineering">
  <rdf:type rdf:resource="#Department"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Track_Structures">
  <rdf:type rdf:resource="#System"/>
  <belongsTo rdf:resource="#Engineering"/>
  <hasSymptom rdf:resource="#ROW_NDF"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ROW_NDF">
  <rdf:type rdf:resource="#Symptom"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Lavatories_Toilets">
  <rdf:type rdf:resource="#System"/>
  <belongsTo rdf:resource="#Mechanical"/>
  <hasSymptom rdf:resource="#To_Be_Determined"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#To_Be_Determined">
  <rdf:type rdf:resource="#Symptom"/>
</owl:NamedIndividual>


</rdf:RDF>

<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/lts_delay_class_based.owl"
         xmlns="http://test.org/lts_delay_class_based.owl#">

<owl:Ontology rdf:about="http://test.org/lts_delay_class_based.owl"/>

<owl:ObjectProperty rdf:about="#has_System">
  <rdfs:domain rdf:resource="#Department"/>
  <rdfs:range rdf:resource="#System"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_Symptom">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#Symptom"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Department">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#System">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Symptom">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Dept_Mechanical">
  <rdfs:subClassOf rdf:resource="#Department"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#has_System"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="#Sys_Head_End_Power"/>
            <rdf:Description rdf:about="#Sys_Brake_and_Air_Supply"/>
            <rdf:Description rdf:about="#Sys_Power_Collection"/>
            <rdf:Description rdf:about="#Sys_Lavatories_and_Toilets"/>
            <rdf:Description rdf:about="#Sys_Derailment"/>
            <rdf:Description rdf:about="#Sys_Lighting"/>
            <rdf:Description rdf:about="#Sys_Employee_Injury"/>
            <rdf:Description rdf:about="#Sys_Unscheduled_Turn_Of_Equipment"/>
            <rdf:Description rdf:about="#Sys_Fuel_Supply"/>
            <rdf:Description rdf:about="#Sys_Communication"/>
            <rdf:Description rdf:about="#Sys_Propulsion_and_Dynamic_Brake"/>
            <rdf:Description rdf:about="#Sys_Trucks_and_Suspension"/>
            <rdf:Description rdf:about="#Sys_Main_and_Aux_Electric_Power"/>
            <rdf:Description rdf:about="#Sys_Cab_Signal_ATC"/>
            <rdf:Description rdf:about="#Sys_Consist"/>
            <rdf:Description rdf:about="#Sys_Controls_and_Diagnostics"/>
            <rdf:Description rdf:about="#Sys_Main_Diesel_Engine"/>
            <rdf:Description rdf:about="#Sys_HVAC"/>
            <rdf:Description rdf:about="#Sys_Doors"/>
            <rdf:Description rdf:about="#Sys_Car_Cleaning"/>
            <rdf:Description rdf:about="#Sys_Checked_Equipment_No_Defect_Found"/>
            <rdf:Description rdf:about="#Sys_Carbody"/>
            <rdf:Description rdf:about="#Sys_Unclassified"/>
          </owl:unionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mechanical</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#Sys_Unclassified">
  <rdfs:subClassOf rdf:resource="#System"/>
  <rdfs:subClassOf>
    <owl:Restriction>
